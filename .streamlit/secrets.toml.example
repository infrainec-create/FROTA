# Copie este conteúdo para .streamlit/secrets.toml localmente ou configure-o no Streamlit Cloud.
google_sheet_id = "ID_DA_PLANILHA_DO_GOOGLE_SHEETS"
OPENAI_API_KEY = "sua_chave_da_openai"

[gcp_service_account]
type = "service_account"
project_id = "seu-projeto"
private_key_id = "..."
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "sua-conta-de-servico@seu-projeto.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."
